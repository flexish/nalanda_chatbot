# ── LLM Provider: openai | anthropic | openrouter ────────────────────────────
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# ── OpenRouter (free/cheap models) ───────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Embeddings: openai (recommended) | huggingface (offline, no key needed) ──
EMBEDDING_BACKEND=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Storage ───────────────────────────────────────────────────────────────────
VECTORSTORE_PATH=./vectorstore
DATA_FOLDER=./data

# ── Web Search (DuckDuckGo — no API key required) ────────────────────────────
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5

# ── Retrieval & RAG ───────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=4
ENABLE_RERANKING=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MAX_ITERATIVE_HOPS=1
SUMMARIZE_TEXT=true

# ── PDF chunking ──────────────────────────────────────────────────────────────
CHUNK_MAX_CHARS=10000
CHUNK_COMBINE_UNDER=2000
CHUNK_NEW_AFTER=6000

# ── Admin credentials (change in production!) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=nalanda@admin123
USER_USERNAME=guest
USER_PASSWORD=nalanda@guest123
