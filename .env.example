# ── LLM provider: anthropic | openai ────────────────────────────────────────
LLM_PROVIDER=openai 

# Anthropic (Claude) — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (GPT-4o) — required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Vector store path (optional, defaults to ./vectorstore)
# VECTORSTORE_PATH=./vectorstore
VECTORSTORE_PATH=./vectorstore_test

# Data folder path (optional, defaults to ./data)
DATA_FOLDER=./data

# Web search (optional) — augments PDF answers with DuckDuckGo snippets
ENABLE_WEB_SEARCH=false
WEB_SEARCH_MAX_RESULTS=5

# Embeddings: auto | huggingface | openai
# Use openai if torch DLL errors on Windows
EMBEDDING_BACKEND=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SUMMARIZE_TEXT=true